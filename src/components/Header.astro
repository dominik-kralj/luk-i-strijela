---
import { Image } from 'astro:assets';
import logo from '../assets/logo/logo-mark-soil.png';
import { opg } from '../lib/data';

const navItems = [
  { href: '/#products', label: 'Proizvodi' },
  { href: '/#about', label: 'O nama' },
  { href: '/#contact', label: 'Kontakt' },
];
---

<header class="sticky top-0 z-40 border-b border-soil/15 bg-parchment/90 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-2 px-5 py-3 text-center sm:flex-row sm:justify-between sm:py-4 sm:px-8 sm:text-left">
    <a href="/" class="flex items-center gap-3">
      <Image src={logo} alt={opg.name} class="h-10 w-10 object-contain sm:h-12 sm:w-12" />
      <span class="font-display text-base font-semibold tracking-tight text-soil sm:text-xl">
        {opg.name}
      </span>
    </a>
    <nav aria-label="Glavna navigacija">
      <ul class="flex items-center justify-center gap-4 text-sm sm:gap-7 sm:text-base">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="whitespace-nowrap text-soil/80 transition-colors hover:text-arrow"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
