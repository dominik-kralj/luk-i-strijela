---
import SignatureDivider from './SignatureDivider.astro';
import { opg } from '../lib/data';
import { getMapsUrl } from '../lib/format';
---

<section id="about" class="bg-field text-parchment">
  <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
    <div class="grid gap-10 sm:grid-cols-[1.3fr_1fr] sm:gap-16">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-sprout">Naša priča</p>
        <h2 class="mt-2 font-display text-3xl font-semibold sm:text-4xl">O nama</h2>
        <p class="mt-5 max-w-xl text-balance leading-relaxed text-parchment/90 sm:text-lg">
          {opg.story}
        </p>
      </div>

      <div class="flex flex-col gap-6 sm:border-l sm:border-parchment/20 sm:pl-10">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-sprout">Lokacija</p>
          <a
            href={getMapsUrl(opg.location)}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 block text-lg underline decoration-parchment/30 underline-offset-4 transition-colors hover:text-onion-skin"
          >
            {opg.location}
          </a>
        </div>
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-sprout">Dostava</p>
          <p class="mt-1 leading-snug text-parchment/90">{opg.deliveryArea}</p>
        </div>
      </div>
    </div>

    <SignatureDivider tone="dark" />
  </div>
</section>
