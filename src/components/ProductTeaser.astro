---
import ProductCard from './ProductCard.astro';
import { products } from '../lib/data';

const featured = products.slice(0, 4);
---

<section class="mx-auto max-w-6xl px-5 pt-14 sm:px-8 sm:pt-20">
  <div class="flex items-baseline justify-between">
    <h2 class="font-display text-2xl font-semibold text-soil sm:text-3xl">Ovaj tjedan beremo</h2>
    <a href="#products" class="whitespace-nowrap font-mono text-sm text-field hover:text-arrow">
      vidi sve &rarr;
    </a>
  </div>

  <div class="mt-6 grid grid-cols-2 gap-4 sm:mt-8 sm:grid-cols-4 sm:gap-6">
    {featured.map((product, i) => (
      <ProductCard product={product} eager={i < 2} />
    ))}
  </div>
</section>
