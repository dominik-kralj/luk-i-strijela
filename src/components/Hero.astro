---
import { Image } from 'astro:assets';
import { opg, getPhotoImage } from '../lib/data';

const heroImages = opg.heroImages;
const [firstImage, ...restImages] = heroImages;
---

<section id="top" class="relative overflow-hidden" data-hero-carousel>
  <div
    class="relative h-[68vh] min-h-[420px] w-full cursor-grab touch-pan-y select-none active:cursor-grabbing sm:h-[78vh]"
    data-hero-track
  >
    <Image
      src={getPhotoImage(firstImage)}
      alt={`Polje OPG-a ${opg.name}`}
      class="pointer-events-none absolute inset-0 z-0 h-full w-full object-cover transition-opacity duration-1000 ease-in-out"
      data-hero-slide={0}
      draggable={false}
      widths={[800, 1200, 1600, 2000]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />

    {/*
      Remaining slides are inert until after window `load` fires (see script below).
      A <template> tag's contents are not fetched by the browser, so these large
      photos don't compete with the LCP image for bandwidth on first paint.
    */}
    {restImages.map((fileName, i) => (
      <template data-hero-slide-template={i + 1}>
        <Image
          src={getPhotoImage(fileName)}
          alt=""
          class="pointer-events-none absolute inset-0 z-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out"
          data-hero-slide={i + 1}
          draggable={false}
          widths={[800, 1200, 1600, 2000]}
          sizes="100vw"
          loading="lazy"
        />
      </template>
    ))}

    <div class="pointer-events-none absolute inset-0 z-10 bg-gradient-to-t from-soil/85 via-soil/20 to-transparent"></div>

    <div class="absolute inset-x-0 bottom-0 z-20 px-5 pb-10 sm:px-10 sm:pb-14">
      <div class="mx-auto max-w-6xl">
        <h1 class="text-balance font-display text-4xl font-semibold leading-tight text-parchment sm:text-6xl">
          {opg.name}
        </h1>
        <p class="mt-3 max-w-md text-balance font-body text-base text-parchment/90 sm:mt-4 sm:text-lg">
          {opg.tagline}
        </p>
        <a
          href="#products"
          class="mt-6 inline-block rounded-sm bg-onion-skin px-6 py-3 font-body text-sm font-medium text-soil shadow-sm transition-transform hover:-translate-y-0.5 hover:bg-onion-skin/90 sm:text-base"
        >
          Pogledaj ponudu
        </a>
      </div>
    </div>

    {heroImages.length > 1 && (
      <div class="pointer-events-none absolute bottom-4 left-1/2 z-20 flex -translate-x-1/2 gap-2 sm:bottom-6">
        {heroImages.map((_, i) => (
          <button
            type="button"
            data-hero-dot={i}
            aria-label={`Fotografija ${i + 1}`}
            data-active={i === 0}
            class="pointer-events-auto h-2 w-2 rounded-full bg-parchment/40 transition-colors data-[active=true]:bg-parchment"
          ></button>
        ))}
      </div>
    )}
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('[data-hero-carousel]');
  const track = root?.querySelector<HTMLElement>('[data-hero-track]');
  const dots = Array.from(root?.querySelectorAll<HTMLElement>('[data-hero-dot]') ?? []);

  if (root && track && dots.length > 1) {
    function setUpCarousel() {
      // Instantiate the deferred slide templates now that the critical
      // first paint / LCP image is out of the way.
      const templates = Array.from(track!.querySelectorAll<HTMLTemplateElement>('[data-hero-slide-template]'));
      templates.forEach((tpl) => {
        track!.appendChild(tpl.content.cloneNode(true));
        tpl.remove();
      });

      const slides = Array.from(track!.querySelectorAll<HTMLElement>('[data-hero-slide]'));
      if (slides.length < 2) return;

      let index = 0;
      let timer: ReturnType<typeof setInterval> | undefined;

      function show(next: number) {
        index = (next + slides.length) % slides.length;
        slides.forEach((slide, i) => {
          slide.style.opacity = i === index ? '1' : '0';
        });
        dots.forEach((dot, i) => dot.setAttribute('data-active', String(i === index)));
      }

      function restart() {
        if (timer) clearInterval(timer);
        timer = setInterval(() => show(index + 1), 6000);
      }

      dots.forEach((dot, i) =>
        dot.addEventListener('click', () => {
          show(i);
          restart();
        })
      );

      // Drag/swipe: works for both touch and mouse via pointer events.
      let startX = 0;
      let dragging = false;

      track!.addEventListener('pointerdown', (event) => {
        dragging = true;
        startX = event.clientX;
      });

      track!.addEventListener('pointerup', (event) => {
        if (!dragging) return;
        dragging = false;
        const delta = event.clientX - startX;
        const threshold = 40;
        if (delta > threshold) {
          show(index - 1);
          restart();
        } else if (delta < -threshold) {
          show(index + 1);
          restart();
        }
      });

      track!.addEventListener('pointerleave', () => {
        dragging = false;
      });

      restart();
    }

    if (document.readyState === 'complete') {
      setUpCarousel();
    } else {
      window.addEventListener('load', setUpCarousel);
    }
  }
</script>
