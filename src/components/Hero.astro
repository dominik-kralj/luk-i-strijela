---
import { Image } from 'astro:assets';
import heroImage from '../assets/photos/field-sunset.jpg';
import { opg } from '../lib/data';
---

<section id="top" class="relative overflow-hidden">
  <div class="relative h-[68vh] min-h-[420px] w-full sm:h-[78vh]">
    <Image
      src={heroImage}
      alt={`Polje OPG-a ${opg.name}`}
      class="h-full w-full object-cover"
      widths={[800, 1200, 1600]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-soil/85 via-soil/20 to-transparent"></div>

    <div class="absolute inset-x-0 bottom-0 px-5 pb-10 sm:px-10 sm:pb-14">
      <div class="mx-auto max-w-6xl">
        <h1 class="text-balance font-display text-4xl font-semibold leading-tight text-parchment sm:text-6xl">
          {opg.name}
        </h1>
        <p class="mt-3 max-w-md text-balance font-body text-base text-parchment/90 sm:mt-4 sm:text-lg">
          {opg.tagline}
        </p>
        <a
          href="#products"
          class="mt-6 inline-block rounded-sm bg-onion-skin px-6 py-3 font-body text-sm font-medium text-soil shadow-sm transition-transform hover:-translate-y-0.5 hover:bg-onion-skin/90 sm:text-base"
        >
          Pogledaj ponudu
        </a>
      </div>
    </div>
  </div>
</section>
