---
import { Image } from 'astro:assets';
import logoSoil from '../assets/logo/logo-mark-soil.png';
import logoParchment from '../assets/logo/logo-mark-parchment.png';

interface Props {
  tone?: 'light' | 'dark';
  size?: 'sm' | 'md';
  class?: string;
}

const { tone = 'light', size = 'md', class: className = '' } = Astro.props;
const mark = tone === 'dark' ? logoParchment : logoSoil;
const wrapperClass = size === 'sm' ? 'py-0' : 'py-10 sm:py-14';
const imageClass = size === 'sm' ? 'h-9 w-9' : 'h-20 w-20 sm:h-24 sm:w-24';
---

<div class:list={['flex justify-center', wrapperClass, className]} aria-hidden="true">
  <Image src={mark} alt="" class:list={[imageClass, 'object-contain opacity-90']} />
</div>
