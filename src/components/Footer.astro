---
import SignatureDivider from './SignatureDivider.astro';
import { opg } from '../lib/data';
import { getMapsUrl } from '../lib/format';

const year = new Date().getFullYear();
---

<footer class="bg-soil text-parchment/80">
  <div class="mx-auto max-w-6xl px-5 pt-4 sm:px-8">
    <SignatureDivider tone="dark" />
  </div>

  <div class="mx-auto max-w-6xl px-5 pb-10 text-center sm:px-8">
    <p class="font-display text-lg text-parchment">{opg.name}</p>
    <a
      href={getMapsUrl(opg.location)}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-1 inline-block text-sm underline decoration-parchment/30 underline-offset-4 transition-colors hover:text-onion-skin"
    >
      {opg.location}
    </a>

    {opg.social && (opg.social.instagram || opg.social.facebook) && (
      <div class="mt-5 flex justify-center gap-5">
        {opg.social.instagram && (
          <a
            href={opg.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="text-parchment/70 transition-colors hover:text-onion-skin"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4.2" />
              <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none" />
            </svg>
          </a>
        )}
        {opg.social.facebook && (
          <a
            href={opg.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="text-parchment/70 transition-colors hover:text-onion-skin"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <circle cx="12" cy="12" r="9" />
              <path d="M13.8,21 L13.8,13.2 L16.2,13.2 L16.6,10.2 L13.8,10.2 L13.8,8.4 C13.8,7.6 14,7 15.2,7 L16.7,7 L16.7,4.3 C16.1,4.2 15.3,4.1 14.4,4.1 C12.3,4.1 10.9,5.4 10.9,7.7 L10.9,10.2 L8.6,10.2 L8.6,13.2 L10.9,13.2 L10.9,21" />
            </svg>
          </a>
        )}
      </div>
    )}

    <p class="mt-5 font-mono text-xs uppercase tracking-widest text-parchment/50">
      &copy; {year} {opg.name}
    </p>
  </div>
</footer>
